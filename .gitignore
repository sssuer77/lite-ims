# === 系统与 IDE 配置文件 ===
.idea/
.vscode/
*.iml
*.iws
*.ipr
.DS_Store
Thumbs.db

# === 后端 (Java/Maven) ===
# 忽略所有层级下的 target 目录（编译产物）
**/target/
*.class
*.log
# 如果你不想要 Maven 运行日志
*.txt

# === 前端 (Node/Vite) ===
# 忽略所有层级下的 node_modules
**/node_modules/
# 忽略前端打包产物
**/dist/
# 忽略本地环境变量文件（防止泄露密钥）
.env
.env.local
.env.*.local
# 忽略 npm 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Python (保留你原有的) ===
__pycache__/
*.pyc
.venv/
venv/
ENV/

# === 其他 ===
# 忽略本地临时文件
.temp/
.tmp/